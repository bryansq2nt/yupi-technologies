# YupiTech FTP deploy settings
# Copy to .deploy.env and fill in FTP_PASSWORD, or leave FTP_PASSWORD blank
# and the deploy script will ask for it securely in the terminal.

FTP_HOST=ftp.mutechlabs.com
FTP_PORT=21
FTP_USERNAME=admin@mutechlabs.com
FTP_PASSWORD=

# Confirm this with:
#   python3 scripts/deploy_ftp.py --list-root
#
FTP_REMOTE_DIR=/yupitech.mutechlabs.com/public_html
FTP_LOCAL_DIR=.

# Keep this on unless the host rejects explicit FTPS.
FTP_TLS=1
FTP_TIMEOUT=45

# These remote files/folders are never deleted by --prune.
FTP_PROTECTED_PATHS=.env,.ftpquota,.well-known,.well-known/*,cgi-bin,cgi-bin/*,logs,logs/*,webstats,webstats/*

# These local files are never uploaded.
FTP_EXCLUDE=.git,.git/*,.gitignore,.deploy.env,.deploy.env.example,.DS_Store,__pycache__,*.pyc,*.md,scripts,scripts/*,work,work/*
